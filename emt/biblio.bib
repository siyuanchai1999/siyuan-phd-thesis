@TechReport{chase:64bit:tr,
  author =      "J. S. Chase and H. M. Levy and M. Baker-Harvey and
        E. D. Lazowska",
  title =       "How to Use a 64-Bit Virtual Address Space",
  institution =         "University of Washington",
  year =        1992,
  REMOVE__number =   "TR 92-03-02",
  annotation =     "OS should support single gloval VAS - a given piece of data
    appears at a fixed virtual address independent of where it is stored or
    which domains access it.
    Virtual addresses are context-independent.  Removes need for hardware
    support for multiple address translations and trouble free virtually
    addressed data cache.
    Private address space serves three functions:
            1) contiguity - each process sees dedicated machine w/ linear
            address space.
            2) Isolation - cannot name data not belonging to process since
            everything interpreted relative to it (i.e., P1, P2 will have
            different interps of 0xfff3)
            3) Reclamation - storage reclamation is trivial - no pointers
            to the process data can exist outside of the process.
        OPAL domain is exactly a process stripped of everything but its
    protection identity."
}
@Article{traub:thread,
  author =      "K.R. Traub and D.E. Culler and K.E. Schauser",
  title =       "Global Analysis for Partitioning Non-Strict Programs into Sequential Threads",
  journal =     "",
  year =        "",
  annotation =     "A thread is defined as:
    1) A compile-time instruction ordering can be determined for the thread
    which is valid for all contexts in which the containg procedure can be
    invoked.
    2) Once the first instruction in a thread is executed, it is always
    possible to to execute each of the remaining instructions, in the
    compile-time ordering, without pause interruption or execution of
    instructions from other threads.

    Thread decomposition and coalescing is quantified."
}
@Article{culler:tam:asplos,
  author =      "D. E. Culler and A. Sah and K.E. Schauser and T. von Eicken and J. Wawrzynek",
  title =       "Fine-grain parallelism with Minimal Hardware Support: A compiler-controlled Threaded Abstract Machine",
  journal =     "Fourth Int. Conf. on Arch. Support for Prog. Lang. and OS",
  year =        "",
  annotation =     "Overview of TAM:
    Goal of TAM: locality management and mulithreading.  Threads are
    basically basic blocks.  TAM code block is constructed of several
    threads and inlets (for mesg reception).

    invoke code block: allocate activation frame (for locals) depositing
    args enabling threads.

    Thread sequences of instructions: contains no jumps or suspension points
    sync occurs only at top of thread.

    fork enables thread in current activation.  stop terminates and starts
    another thread.   thread enabled when entry count = 0, dec by fork.

    when no enabled threads remain, another activation must be made resident
    AF has enter and leave threads responsible for save/restore of regs.

    synchronization occurs only at entrance and conditional execution
    occurs only between threads.

    Fundamentatl limit on partitioning: dependence that can only be resolved
    dynamically."
}
@Article{schauser:parallel:lang,
